# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (Tell Me How + card chat) — routes to Claude Sonnet by default.
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: swap to any OpenRouter model without code changes. See https://openrouter.ai/models
# AI_MODEL=anthropic/claude-sonnet-4.5

# Web push (generate once: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Telnyx SMS fallback (A2P 10DLC registered number)
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+1XXXXXXXXXX

# Resend (invites, dispute notifications, digests)
RESEND_API_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
SENTRY_DSN=

# Vercel Cron protection
CRON_SECRET=generate-a-long-random-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
